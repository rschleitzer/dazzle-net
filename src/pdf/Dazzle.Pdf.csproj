<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Dazzle.Pdf</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <NoWarn>CS8632;CS0109;CS0414</NoWarn>
    <LangVersion>preview</LangVersion>

    <!-- NuGet Package -->
    <PackageId>Dazzle.Pdf</PackageId>
    <Version>0.1.0</Version>
    <Authors>Ralf Schleitzer</Authors>
    <Description>DSSSL-to-PDF processor using OpenJade and QuestPDF. Includes table support and a clean DssslProcessor API.</Description>
    <PackageTags>dsssl;openjade;pdf;questpdf</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/rschleitzer/dazzle-net</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenSP" Version="*" />
    <PackageReference Include="OpenJade" Version="*" />
    <PackageReference Include="QuestPDF" Version="2025.*" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="sgml\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <PackageCopyToOutput>true</PackageCopyToOutput>
    </Content>
  </ItemGroup>

</Project>
